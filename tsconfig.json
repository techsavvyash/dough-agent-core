{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@dough/protocol": ["./packages/protocol/src"],
      "@dough/threads": ["./packages/threads/src"],
      "@dough/core": ["./packages/core/src"],
      "@dough/server": ["./packages/server/src"],
      "@dough/tui": ["./packages/tui/src"],
      "@dough/sdk": ["./packages/sdk/src"]
    }
  }
}
